# Copy this file to .env, replace the placeholder, and never commit .env.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_REALTIME_VOICE remains a backward-compatible Neutral voice setting.
OPENAI_REALTIME_VOICE=marin
OPENAI_COGNITIVE_VOICE=cedar
OPENAI_NEUTRAL_VOICE=marin
OPENAI_AFFECTIVE_VOICE=coral
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_INPUT_LANGUAGE=en
OPENAI_SAFETY_IDENTIFIER=local-demo-user

## Python CA certifi bundle path for SSL verification. (Use on Mac, comment out on Windows.)
# SSL_CERT_FILE=/Library/Frameworks/Python.framework/Versions/3.8/lib/python3.8/site-packages/certifi/cacert.pem


APP_HOST=127.0.0.1
APP_PORT=8000

TLS_CERT_FILE=
TLS_KEY_FILE=
